HTTP_PORT=8080

DB_PATH=./dbserver/social.db

JWT_SECRET=super-secret-key
JWT_TTL=24h

STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# Set to true only when Kafka is running.
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092

# Messenger service
GRPC_ADDR=:9090
HTTP_ADDR=:8082
REDIS_ADDR=localhost:6379
POSTGRES_DSN=postgres://gav:gav@localhost:5432/gav?sslmode=disable
SOCIAL_NETWORK_ADDR=localhost:9000
