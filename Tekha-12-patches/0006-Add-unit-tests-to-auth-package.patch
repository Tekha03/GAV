@@ -0,0 +1,327 @@
+package auth
+
+import (
+	"context"
+	"gav/internal/user"
+	"testing"
+	"time"
+
+	"github.com/google/uuid"
+	"github.com/stretchr/testify/assert"
+	"github.com/stretchr/testify/mock"
+	"github.com/stretchr/testify/require"
+)
+
+type testEnv struct {
+	userService 	*MockUserService
+	tokenService 	*MockTokenService
+	userID			uuid.UUID
+	service			AuthService
+	cfg 			JWTConfig
+	hasher			*PasswordHasher
+}
+
+func setupAuthService(t *testing.T) *testEnv {
+	t.Helper()
+
+	userService := &MockUserService{}
+	tokenService := &MockTokenService{}
+	hasher := &PasswordHasher{}
+
+	userID := uuid.New()
+
+	cfg := JWTConfig{
+		Secret: []byte("secret"),
+		TTL: time.Hour,
+	}
+
+	service, err := NewService(userService, tokenService, cfg, hasher)
+	require.NoError(t, err)
+
+	return &testEnv{
+		userService: 	userService,
+		tokenService: 	tokenService,
+		userID: 		userID,
+		service: 		service,
+		cfg: 			cfg,
+		hasher: 		hasher,
+	}
+}
+
+func TestNewService(t *testing.T) {
+	env := setupAuthService(t)
+	assert.NotNil(t, env.service)
+}
+
+func TestNewService_UserServiceNil(t *testing.T) {
+	cfg := JWTConfig{
+		Secret: []byte("secret"),
+	}
+
+	service, err := NewService(nil, &MockTokenService{}, cfg, &PasswordHasher{})
+
+	assert.Error(t, err)
+	assert.Nil(t, service)
+	assert.Equal(t, ErrUserServiceNil, err)
+}
+
+func TestNewService_TokenServiceNil(t *testing.T) {
+	cfg := JWTConfig{
+		Secret: []byte("secret"),
+	}
+
+	service, err := NewService(&MockUserService{}, nil, cfg, &PasswordHasher{})
+
+	assert.Error(t, err)
+	assert.Nil(t, service)
+	assert.Equal(t, ErrTokenServiceNil, err)
+}
+
+func TestRegister_Success(t *testing.T) {
+	env := setupAuthService(t)
+	ctx := context.Background()
+
+	mail := "test@mail.com"
+
+	env.userService.
