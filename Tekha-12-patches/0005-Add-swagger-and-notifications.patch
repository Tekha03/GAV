+	Schemes:          []string{},
+	Title:            "Dog Lovers API (GAV)",
+	Description:      "Социальная сеть для любителей собак",
+	InfoInstanceName: "swagger",
+	SwaggerTemplate:  docTemplate,
+	LeftDelim:        "{{",
+	RightDelim:       "}}",
+}
+
+func init() {
+	swag.Register(SwaggerInfo.InstanceName(), SwaggerInfo)
+}
